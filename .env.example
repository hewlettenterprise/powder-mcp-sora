# Required: Your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: Override the OpenAI API base URL (default: https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Default model for video generation (default: sora-2)
SORA_DEFAULT_MODEL=sora-2

# Optional: Maximum polling duration in seconds (default: 300)
SORA_MAX_POLL_SECONDS=300

# Optional: Polling interval in milliseconds (default: 5000)
SORA_POLL_INTERVAL_MS=5000

# Optional: Enable debug logging (default: false)
SORA_DEBUG=false

# Optional: Comma-separated list of directories allowed for local file uploads (default: /tmp)
SORA_ALLOWED_UPLOAD_DIRS=/tmp,/var/uploads
